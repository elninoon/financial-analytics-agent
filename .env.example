# 复制此文件为 .env，并填入你的真实密钥。
# .env 已被 .gitignore 排除，不会被提交到 Git 仓库，可以放心填写真实密钥。

# ==================== LLM API 配置 ====================
# OpenAI:    LLM_BASE_URL=https://api.openai.com/v1                                  LLM_MODEL_NAME=gpt-4o
# Qwen:      LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1          LLM_MODEL_NAME=qwen-plus
# DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1                                LLM_MODEL_NAME=deepseek-chat

LLM_API_KEY=sk-your-real-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
